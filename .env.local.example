# ─── Data + AI (đã setup từ trước) ───────────────────────────────────────
PIXABAY_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ─── NextAuth (mới) ──────────────────────────────────────────────────────
# Chạy: openssl rand -base64 32
NEXTAUTH_SECRET=
# Dev: http://localhost:3000  |  Production: https://yourdomain.com
NEXTAUTH_URL=http://localhost:3000

# ─── Google OAuth ────────────────────────────────────────────────────────
# 1. https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID → Web application
# 3. Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
#    Dev: http://localhost:3000/api/auth/callback/google
#    Prod: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Vercel KV ───────────────────────────────────────────────────────────
# 1. https://vercel.com/dashboard/stores → Create Database → KV
# 2. Connect to project → Copy all 4 env vars từ tab ".env.local"
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
